                  {
                      "id":  "sched-find-01",
                      "name":  "Determinar Estado",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       680,
                                       300
                                   ],
                      "parameters":  {
                                         "jsCode":  "const rows = $input.all().map(i =\u003e i.json);\n\n// Activo = cualquier estado que NO sea done, error ni waiting_link\n// Si hay algo en proceso -\u003e parar, dejar que termine\nconst hasActive = rows.some(r =\u003e {\n  const s = (r.estatus || \u0027\u0027).toLowerCase().trim();\n  return s \u0026\u0026 ![\u0027done\u0027, \u0027error\u0027, \u0027waiting_link\u0027].includes(s);\n});\nif (hasActive) return [{ json: { estado: \u0027activo\u0027 } }];\n\n// Solo waiting_link -\u003e actualizar timestamp, sin mandar Telegram de nuevo\nconst wl = rows.find(r =\u003e (r.estatus || \u0027\u0027).toLowerCase().trim() === \u0027waiting_link\u0027);\nif (wl) return [{ json: { estado: \u0027esperando\u0027, row_number: wl.row_number } }];\n\n// Todo done/error o sheet vacio -\u003e crear nuevo ciclo\nreturn [{ json: { estado: \u0027nuevo\u0027 } }];"
                                     }
                  },
