                  {
                      "id":  "rec-code-01",
                      "name":  "Enviar Recordatorios",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       220,
                                       0
                                   ],
                      "parameters":  {
                                         "jsCode":  "const sd = $getWorkflowStaticData(\u0027global\u0027);\n// ⏱ INTERVALO: 1 min para pruebas → cambiar a 2*60*60*1000 para produccion\nconst REMINDER_MS = 1 * 60 * 1000;\nconst TOKEN = $env.TELEGRAM_BOT_TOKEN;\nconst CHAT  = $env.TELEGRAM_CHAT_ID;\nconst now   = Date.now();\n\nif (!sd.reminders) sd.reminders = {};\n\nconst tg = async (text, extra = {}) =\u003e this.helpers.httpRequest({\n  method: \u0027POST\u0027,\n  url: \u0027https://api.telegram.org/bot\u0027 + TOKEN + \u0027/sendMessage\u0027,\n  body: { chat_id: CHAT, text, ...extra },\n  json: true,\n});\n\nconst rows = $input.all().map(i =\u003e i.json);\n\n// Si hay articulo activo (waiting_confirm/pending/waiting/ready), no recordar waiting_link\nconst hasActiveArticle = rows.some(r =\u003e [\u0027waiting_confirm\u0027,\u0027pending\u0027,\u0027waiting\u0027,\u0027ready\u0027].includes((r.estatus||\u0027\u0027).toLowerCase().trim()));\n\nfor (const row of rows) {\n  const estatus = (row.estatus || \u0027\u0027).toLowerCase().trim();\n  if (![\u0027waiting_link\u0027,\u0027waiting_confirm\u0027,\u0027pending\u0027,\u0027waiting\u0027].includes(estatus)) continue;\n\n  // Si hay articulo activo, saltar los waiting_link\n  if (estatus === \u0027waiting_link\u0027 \u0026\u0026 hasActiveArticle) continue;\n\n  const key = \u0027row_\u0027 + (row.row_number || row.articulo);\n  const lastReminder = sd.reminders[key] || 0;\n  if (now - lastReminder \u003c REMINDER_MS) continue;\n\n  // waiting_link: solo recordar si la fila es de HOY\n  if (estatus === \u0027waiting_link\u0027 \u0026\u0026 row.procesado_en) {\n    const rowDate = new Date(row.procesado_en);\n    const today   = new Date();\n    if (rowDate.toDateString() !== today.toDateString()) continue;\n  }\n\n  let msg = \u0027\u0027;\n  let extra = {};\n  if (estatus === \u0027waiting_link\u0027) {\n    msg = \u0027👋 Ey, aún te estoy esperando! ¿Con qué artículo trabajamos hoy?\\n\\nMandame el link de Mercado Libre 🔗\u0027;\n  } else if (estatus === \u0027waiting_confirm\u0027) {\n    msg = \u0027👋 Sigo esperando tu respuesta!\u0027;\n    extra = { reply_markup: { keyboard: [[{text: \u0027/articulo_correcto\u0027}, {text: \u0027/articulo_incorrecto\u0027}]], resize_keyboard: true, one_time_keyboard: true } };\n  } else if (estatus === \u0027pending\u0027) {\n    msg = \u0027👋 Sigo esperando tu confirmación!\u0027;\n    extra = { reply_markup: { keyboard: [[{text: \u0027/articulo_correcto\u0027}, {text: \u0027/articulo_incorrecto\u0027}]], resize_keyboard: true, one_time_keyboard: true } };\n  } else if (estatus === \u0027waiting\u0027) {\n    msg = \u0027👋 Sigo esperando el link de afiliado!\\n\\nGeneralo en ML Partners y respondelo al mensaje anterior 🔗\u0027;\n  }\n\n  if (!msg) continue;\n  await tg(msg, extra);\n  sd.reminders[key] = now;\n}\n\nreturn [];"
                                     }
                  }
              ],
