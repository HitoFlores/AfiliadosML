                                         "jsCode":  "const rows = $(\u0027Get Queue EH\u0027).all().map(i =\u003e i.json);\nconst row = rows.find(r =\u003e (r.estatus||\u0027\u0027).toString().trim().toLowerCase() === \u0027processing\u0027);\nconst err = $(\u0027Error Trigger\u0027).first().json;\nconst msg = (err?.execution?.error?.message || err?.error?.message || \u0027Error desconocido\u0027).toString().slice(0,300);\nif (!row) return [];\nreturn [{ json: { row_number: row.row_number, error_msg: msg } }];"
